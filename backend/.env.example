APP_NAME="Voyage Assistant API"
DEBUG=true

DATABASE_URL="sqlite:///./voyage.db"

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# LLM (optionnel — pour la version LangChain + Gemini à venir)
GEMINI_API_KEY=""
TAVILY_API_KEY=""

# Brevo (compte séparé, pas celui du patron)
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Voyage Assistant"

# RAG
RAG_INDEX_DIR="./app/rag/store"

# Admin par défaut (utilisé par seed.py)
ADMIN_DEFAULT_EMAIL="admin@voyage.local"
ADMIN_DEFAULT_PASSWORD="changeme"
